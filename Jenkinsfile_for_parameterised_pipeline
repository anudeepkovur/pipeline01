pipeline {
    agent any

    parameters {
        string(
            defaultValue: 'TEST',
            description: 'Environment to deploy the application',
            name: 'ENV',
            trim: true
        )

        choice(
            choices: ['main', 'master'],
            description: 'Branch to deploy',
            name: 'BRANCH'
        )
    }

    stages {
        stage('BUILD') {
            agent any
            steps {
                echo "This is Build stage"
                sh 'sleep 5'
                echo "Deploying to ${ENV}"
                echo "Code from ${BRANCH} branch"
            }
        }
    }
}
