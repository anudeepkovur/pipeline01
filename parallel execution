pipeline {
    agent none
    stages {
        stage('BUILD') {
            agent { label 'master' }
            steps {
                echo "This is Build stage"
                sh 'echo Building on master'
                sh 'sleep 5'
            }
        }
        stage('TEST') {
            agent { label 'label-8' }
            steps {
                echo "This is Test stage"
                sh 'echo Testing on label-8'
                sh 'sleep 5'
            }
        }
        stage('DEPLOY') {
            agent { label 'label-8' }
            steps {
                echo "This is Deploy stage"
                sh 'echo Deploying on label-8'
                sh 'sleep 5'
            }
        }
        stage('PARALLEL TESTS') {
            parallel {
                stage('DEV') {
                    agent { label 'label-8' }
                    steps {
                        echo "This is Test in DEV stage"
                        sh 'echo Testing in dev on label-8'
                        sh 'sleep 5'
                    }
                }
                stage('TST') {
                    agent { label 'label-8' }
                    steps {
                        echo "This is Test in TST stage"
                        sh 'echo Testing in tst on label-8'
                        sh 'sleep 5'
                    }
                }
                stage('PERF') {
                    agent { label 'label-8' }
                    steps {
                        echo "This is Test in PERF stage"
                        sh 'echo Testing in perf on label-8'
                        sh 'sleep 5'
                    }
                }
            }
        }
    }
}
